{
  "expo": {
    "name": "Relio",
    "slug": "relio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5EFE7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.relio.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Relio uses Face ID to protect your private journal entries.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5EFE7"
      },
      "package": "com.relio.app",
      "versionCode": 1,
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "scheme": "relio",
    "plugins": [
      "expo-secure-store",
      "expo-local-authentication",
      "expo-asset",
      "expo-font",
      "expo-localization",
      "@sentry/react-native"
    ],
    "extra": {
      "eas": {
        "projectId": "9cf03af7-e845-430a-9fd5-238ebbf09044"
      }
    },
    "owner": "send2katzs-organization"
  }
}
