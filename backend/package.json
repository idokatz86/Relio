{
  "name": "@relio/backend",
  "version": "0.1.0",
  "description": "Relio AI Relationship Mediation Backend - 5-Agent MVP Pipeline",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/server/app.ts",
    "build": "tsc",
    "start": "node dist/server/app.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "pipeline:test": "tsx src/pipeline/test-pipeline.ts",
    "server": "tsx src/server/app.ts"
  },
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@github/copilot-sdk": "^0.1.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jose": "^6.2.1",
    "pg": "^8.20.0",
    "uuid": "^13.0.0",
    "ws": "^8.19.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/helmet": "^0.0.48",
    "@types/ioredis": "^4.28.10",
    "@types/node": "^22.12.0",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9.19.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.22.0",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
