# Relio Backend Environment Variables
# Copy to .env and fill in values

# LLM Provider: "github" (free/dev) or "azure" (production BYOK)
LLM_PROVIDER=github

# GitHub Models API (Phase 0 - Development)
GITHUB_TOKEN=your_github_pat_here

# Azure OpenAI (Phase 1 - Production, after Pre-Seed)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your_key_here
# AZURE_OPENAI_DEPLOYMENT_GPT54=gpt-54
# AZURE_OPENAI_DEPLOYMENT_GPT53_CODEX=gpt-53-codex

# Anthropic (Phase 1 - Production)
# ANTHROPIC_API_KEY=your_key_here

# Vertex AI / Gemini (Phase 1 - Production)
# GOOGLE_PROJECT_ID=your_project_id
# GOOGLE_APPLICATION_CREDENTIALS=path/to/credentials.json

# Application
NODE_ENV=development
LOG_LEVEL=debug
PORT=3000
