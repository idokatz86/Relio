# Relio Backend Environment Variables
# Copy to .env and fill in values

# LLM Provider: "github" (free/dev) or "azure" (production BYOK)
LLM_PROVIDER=github

# GitHub Models API (Phase 0 - Development)
GITHUB_TOKEN=your_github_pat_here

# Azure OpenAI (Phase 1 - Production, after Pre-Seed)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your_key_here
# AZURE_OPENAI_DEPLOYMENT_GPT54=gpt-54
# AZURE_OPENAI_DEPLOYMENT_GPT53_CODEX=gpt-53-codex

# Anthropic (Phase 1 - Production)
# ANTHROPIC_API_KEY=your_key_here

# Vertex AI / Gemini (Phase 1 - Production)
# GOOGLE_PROJECT_ID=your_project_id
# GOOGLE_APPLICATION_CREDENTIALS=path/to/credentials.json

# Application
NODE_ENV=development
LOG_LEVEL=debug
PORT=3001

# Authentication — Clerk (free tier)
# Set AUTH_DISABLED=true for local dev without IdP
AUTH_DISABLED=true
# CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
# CLERK_SECRET_KEY=sk_test_xxxxx
# JWKS_URI=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
# JWT_ISSUER=https://your-instance.clerk.accounts.dev
# AUTH_AUDIENCE=

# CORS (Issue #76)
# Comma-separated list. Empty = allow all in dev, deny all in production
# ALLOWED_ORIGINS=https://app.relio.co,https://relio.app

# LLM Token Budget (Issue #86)
LLM_DAILY_TOKEN_BUDGET=50000

# Database — PostgreSQL (Issue #65)
# For local dev with docker-compose, use:
POSTGRES_TIER1_URL=postgresql://relioadmin:localdev@localhost:5432/relio_tier1_private
POSTGRES_TIER3_URL=postgresql://relioadmin:localdev@localhost:5432/relio_tier3_shared
AUTO_MIGRATE=true
# For Azure:
# POSTGRES_TIER1_URL=postgresql://relioadmin:password@relio-postgres-dev.postgres.database.azure.com:5432/relio_tier1_private?sslmode=require
# POSTGRES_TIER3_URL=postgresql://relioadmin:password@relio-postgres-dev.postgres.database.azure.com:5432/relio_tier3_shared?sslmode=require

# Database — Cosmos DB (Issue #65)
# COSMOS_ENDPOINT=https://relio-cosmos-dev.documents.azure.com:443/
# COSMOS_KEY=your_key_here

# Redis (Issue #62)
# REDIS_URL=rediss://relio-redis.redis.cache.windows.net:6380

# Application Insights (Issue #64)
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...
